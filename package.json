{
  "name": "sveden-checker",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter @sveden-checker/server --filter @sveden-checker/web dev",
    "dev:server": "pnpm --filter @sveden-checker/server dev",
    "dev:web": "pnpm --filter @sveden-checker/web dev",
    "build": "pnpm -r build",
    "release:win": "pnpm build && node scripts/build-windows-release.mjs && powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/finalize-windows-release.ps1",
    "typecheck": "pnpm -r typecheck",
    "db:init": "pnpm --filter @sveden-checker/database db:init"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3"
  }
}
